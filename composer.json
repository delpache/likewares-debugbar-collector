{
    "name": "likewares/laravel-likewares-collector",
    "description": "Package Laravel Debugbar collector pour Likewares CRM",
    "keywords": [
        "likewares",
        "laravel",
        "debugbar"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "KOUAOBILE ASSANDE HUGUES",
            "email": "assandehugues@gmail.com",
            "homepage": "https://crm.likewares.com",
            "role": "CEO Developer"
        }
    ],
    "require": {
        "php": "^8.0|^8.1|^8.2|^8.3|^8.4",
        "barryvdh/laravel-debugbar": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^7.4|^8.0|^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^9.5|^10.0|^11.0|^12.0|^13.0"
    },
    "autoload": {
        "psr-4": {
            "Likewares\\LaravelDebugbarCollector\\": "src"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Likewares\\DebugbarCollector\\Provider"
            ]
        }
    }
}
